NODE_ENV=development
PORT=3000
MCP_PATH=/mcp
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mcp_gateway_lite
MASTER_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY
GATEWAY_API_KEY=replace-with-strong-api-key
BEARER_JWT_SECRET=replace-with-hs256-secret
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
SYNC_INTERVAL_CRON=0 */6 * * *
ALLOWED_ORIGINS=http://localhost:3000
REQUEST_TIMEOUT_MS=15000
PULSEMCP_API_KEY=
PULSEMCP_TENANT_ID=
SMITHERY_BEARER_TOKEN=
OFFICIAL_REGISTRY_BASE_URL=https://registry.modelcontextprotocol.io/v0
PULSEMCP_BASE_URL=https://api.pulsemcp.com
SMITHERY_BASE_URL=https://api.smithery.ai
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
OAUTH_REDIRECT_BASE_URL=https://localhost:3000
OAUTH_ALLOWED_REDIRECT_HOSTS=localhost
LOG_LEVEL=info
DISABLE_SYNC_ON_BOOT=false
